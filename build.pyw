                          relief=tk.FLAT, cursor="hand2")
            b.pack(side=tk.LEFT, padx=6)
            Tooltip(b, tip)
            self._git_btns.append(b)

        # ── Console ───────────────────────────────────────────────────────────
        console_frame = tk.LabelFrame(content, text="  Output  ")
        console_frame.pack(fill=tk.BOTH, expand=True, pady=(4, 0))
        self.console = scrolledtext.ScrolledText(
            console_frame, font=("Consolas", self._fsize), wrap=tk.WORD)
        self.console.pack(fill=tk.BOTH, expand=True, padx=2, pady=2)

        # ── Status bar ────────────────────────────────────────────────────────
        sb = tk.Frame(self.root, relief=tk.SUNKEN, bd=1)
        sb.pack(fill=tk.X)
        self._status_var = tk.StringVar(value="Ready")
        tk.Label(sb, textvariable=self._status_var, anchor=tk.W,
                 font=("Segoe UI", 9)).pack(
                     side=tk.LEFT, fill=tk.X, expand=True, padx=4)
        ttk.Sizegrip(sb).pack(side=tk.RIGHT)

    # ── Theme ─────────────────────────────────────────────────────────────────

    def _apply_theme(self):
        t = DARK if self._theme == "dark" else LIGHT
        colors = LOG_COLORS_DARK if self._theme == "dark" else LOG_COLORS_LIGHT
        self.root.configure(bg=t["bg"])
        self._tb.configure(bg=t["bg"])
        self.console.configure(bg=t["console_bg"], fg=t["console_fg"],
                               insertbackground=t["console_fg"])
        for tag, fg in colors.items():
            bold = tag in ("header", "section", "success", "error")
            self.console.tag_configure(
                tag, foreground=fg,
                font=("Consolas", self._fsize, "bold" if bold else "normal"))
        self.console.tag_configure(
            "dim", foreground=colors["dim"],
            font=("Consolas", self._fsize))
        self._theme_btn.config(
            text="☀ Light" if self._theme == "dark" else "🌙 Dark",
            bg=t["bg"], fg=t["fg"])
        for w in self._tb.winfo_children():
            if w is not self._theme_btn:
                try: w.configure(bg=t["bg"], fg=t["fg"])
                except Exception: pass

    def _toggle_theme(self):
        self._theme = "light" if self._theme == "dark" else "dark"
        self.cfg.set("theme", self._theme)
        self._apply_theme()

    def _chg_font(self, d):
        self._fsize = max(7, min(20, self._fsize + d))
        self.console.config(font=("Consolas", self._fsize))
        self.cfg.set("font_size", self._fsize)
        self._apply_theme()

    # ── Logging ───────────────────────────────────────────────────────────────

    def _log(self, msg, tag="info"):
        def _do():
            ts = datetime.now().strftime("%H:%M:%S")
            self.console.insert(tk.END, "[{}]  ".format(ts), "dim")
            self.console.insert(tk.END, "{}\n".format(msg), tag)
            self.console.see(tk.END)
        self.root.after(0, _do)

    def _log_raw(self, msg, tag="dim"):
        def _do():
            self.console.insert(tk.END, "{}\n".format(msg), tag)
            self.console.see(tk.END)
        self.root.after(0, _do)

    def _section(self, title):
        self._log("", "info")
        self._log("═" * 56, "header")
        self._log("  {}".format(title), "header")
        self._log("═" * 56, "header")

    def _clear_log(self):
        self.console.delete("1.0", tk.END)

    def _status(self, m):
        self.root.after(0, lambda: self._status_var.set(m))

    # ── Busy lock ─────────────────────────────────────────────────────────────

    def _lock(self, label="⏳ Working…"):
        self._busy = True
        for b in list(self._btns.values()) + self._git_btns:
            b.config(state=tk.DISABLED)
        self._status(label)

    def _unlock(self):
        self._busy = False
        for key, b in self._btns.items():
            b.config(state=tk.NORMAL, text=BTNS[key]["text"])
        for b in self._git_btns:
            b.config(state=tk.NORMAL)
        self._status("Ready")

    def _thread(self, fn):
        if self._busy:
            messagebox.showwarning("Busy", "An operation is already running.")
            return
        self._lock()
        def runner():
            try:
                fn()
            except Exception as e:
                import traceback
                self._log("UNEXPECTED ERROR: {}".format(e), "error")
                self._log(traceback.format_exc(), "error")
            finally:
                self.root.after(0, self._unlock)
        threading.Thread(target=runner, daemon=True).start()

    # ── Preflight ─────────────────────────────────────────────────────────────

    def _preflight(self):
        self._info["entry"].config(text=str(ENTRY_PY))
        self._info["icon"].config(text=str(ICON_FILE))
        self._info["output"].config(text=str(EXE_PATH))
        self._info["workdir"].config(text=str(SCRIPT_DIR))

        self._section("QiGor Wallpaper Manager — Build Tool  v{}".format(APP_VERSION))

        # Entry point
        if ENTRY_PY.exists():
            self._log("✅  Entry point: {}  ({} KB)".format(
                ENTRY_PY.name, ENTRY_PY.stat().st_size // 1024), "success")
        else:
            self._log("❌  Entry point not found: {}".format(ENTRY_PY), "error")

        # app/ package
        app_dir = SCRIPT_DIR / "app"
        if app_dir.exists():
            py_count = len(list(app_dir.glob("*.py")))
            self._log("✅  app/ package: {} modules".format(py_count), "success")
        else:
            self._log("❌  app/ directory not found!", "error")

        # assets/
        assets_dir = SCRIPT_DIR / "assets"
        if assets_dir.exists():
            count = len(list(assets_dir.iterdir()))
            self._log("✅  assets/: {} files".format(count), "success")
        else:
            self._log("⚠   assets/ directory not found — images won't be bundled", "warning")

        # Icon
        if ICON_FILE.exists():
            self._log("✅  Icon: {}  ({} KB)".format(
                ICON_FILE.name, ICON_FILE.stat().st_size // 1024), "success")
        else:
            self._log("⚠   Icon not found — click '🖼 Regenerate Icon' to create it", "warning")

        # Existing EXE
        if EXE_PATH.exists():
            mb    = EXE_PATH.stat().st_size / (1024 * 1024)
            mtime = datetime.fromtimestamp(
                EXE_PATH.stat().st_mtime).strftime("%Y-%m-%d %H:%M")
            self._log("ℹ   Existing EXE: {:.1f} MB, built {}".format(mb, mtime), "info")

        # PyInstaller
        self._log("", "info")
        self._log("Checking PyInstaller...", "info")
        try:
            r = subprocess.run(
                [sys.executable, "-m", "PyInstaller", "--version"],
                capture_output=True, text=True, timeout=10)
            ver = r.stdout.strip()
            if ver:
                self._log("✅  PyInstaller {}".format(ver), "success")
            else:
                self._log("❌  PyInstaller not found — run:  pip install pyinstaller",
                          "error")
        except Exception:
            self._log("❌  PyInstaller not found — run:  pip install pyinstaller",
                      "error")

        # tkinterdnd2
        try:
            import tkinterdnd2  # noqa
            self._log("✅  tkinterdnd2 found", "success")
        except ImportError:
            self._log("⚠   tkinterdnd2 not installed — DnD will be disabled in EXE."
                      "  pip install tkinterdnd2", "warning")

        # git
        git = shutil.which("git")
        self._log("{}  git: {}".format(
            "✅" if git else "⚠ ", git or "not found — install Git for Windows"),
            "success" if git else "warning")

        self._log("", "info")
        self._log("Ready.  Click 🔨 Build EXE to start.", "info")
        self._log("", "info")

    # ── Icon generation ───────────────────────────────────────────────────────

    def _regen_icon(self):
        """Generate .ico from the bundled assets/qigor_wallpaper_manager_150k.jpg."""
        self._section("GENERATE ICON")
        try:
            from PIL import Image
        except ImportError:
            self._log("❌  Pillow not installed — pip install pillow", "error")
            return

        src = SCRIPT_DIR / "assets" / "qigor_wallpaper_manager_150k.jpg"
        if not src.exists():
            self._log("❌  Source image not found: {}".format(src), "error")
            return

        img = Image.open(str(src))
        # Crop gorilla face area
        cx, cy, half = 490, 160, 220
        w, h = img.size
        cx = min(cx, w - half)
        cy = min(cy, h - half)
        crop = img.crop((cx - half, cy - half, cx + half, cy + half))

        # Build multi-size ICO
        sizes = [256, 128, 64, 48, 32, 16]
        import io, struct

        entries = []
        for s in sizes:
            resized = crop.resize((s, s), Image.LANCZOS).convert("RGBA")
            buf = io.BytesIO()
            resized.save(buf, format="PNG")
            entries.append((s, buf.getvalue()))

        count      = len(entries)
        header     = struct.pack("<HHH", 0, 1, count)
        data_start = 6 + count * 16
        dir_bytes  = b""
        for s, data in entries:
            dir_bytes += struct.pack("<BBBBHHII",
                s if s < 256 else 0,
                s if s < 256 else 0,
                0, 0, 1, 32,
                len(data), data_start)
            data_start += len(data)

        with open(ICON_FILE, "wb") as f:
            f.write(header + dir_bytes)
            for _, data in entries:
                f.write(data)

        self._log("✅  Icon created: {}  ({} KB)".format(
            ICON_FILE.name, ICON_FILE.stat().st_size // 1024), "success")
        self._log("   Sizes: {}".format(", ".join("{}×{}".format(s, s)
                                                   for s, _ in entries)), "info")
        self._info["icon"].config(text=str(ICON_FILE))

    # ── Build EXE ─────────────────────────────────────────────────────────────

    def _start_build(self):
        if not ENTRY_PY.exists():
            messagebox.showerror("Missing",
                "Entry point not found:\n{}".format(ENTRY_PY))
            return
        self._thread(self._do_build)

    def _do_build(self):
        t0 = time.monotonic()
        self._section("BUILD EXE")

        # ── Command ───────────────────────────────────────────────────────────
        # Copy icon to root dir for PyInstaller (it needs it relative to spec)
        root_ico = SCRIPT_DIR / "qigor_wallpaper_manager.ico"
        if ICON_FILE.exists() and not root_ico.exists():
            import shutil as _sh
            _sh.copy2(str(ICON_FILE), str(root_ico))
        effective_icon = root_ico if root_ico.exists() else ICON_FILE

        cmd = [
            sys.executable, "-m", "PyInstaller",
            "--onefile",
            "--windowed",           # no console window
            "--name", "QiGor_Wallpaper_Manager",
            "--distpath", str(SCRIPT_DIR),
            "--workpath", str(BUILD_DIR),
            "--specpath", str(SCRIPT_DIR),
            # Bundle the app/ package
            "--add-data", "{}{}{}".format(
                str(SCRIPT_DIR / "app"), os.pathsep, "app"),
            # Bundle assets/
            "--add-data", "{}{}{}".format(
                str(SCRIPT_DIR / "assets"), os.pathsep, "assets"),
            # tkinterdnd2 has DLLs that need explicit collection
            "--collect-all", "tkinterdnd2",
        ]

        if effective_icon.exists():
            cmd += ["--icon", str(effective_icon)]
            self._log("Icon: {}".format(effective_icon.name), "info")
        else:
            self._log("⚠   No icon — building without", "warning")

        # Write a Windows version info file for proper file properties
        ver_file = SCRIPT_DIR / "_version_info.txt"
        ver_file.write_text(
            "VSVersionInfo(\n"
            "  ffi=FixedFileInfo(\n"
            "    filevers=(0, 7, 0, 0),\n"
            "    prodvers=(0, 7, 0, 0),\n"
            "    mask=0x3f, flags=0x0, OS=0x40004,\n"
            "    fileType=0x1, subtype=0x0,\n"
            "    date=(0, 0)),\n"
            "  kids=[\n"
            "    StringFileInfo([StringTable('040904B0', [\n"
            "      StringStruct('CompanyName', 'frankksutta'),\n"
            "      StringStruct('FileDescription', 'QiGor Wallpaper Manager'),\n"
            "      StringStruct('FileVersion', '0.7.0.0'),\n"
            "      StringStruct('InternalName', 'QiGor_Wallpaper_Manager'),\n"
            "      StringStruct('LegalCopyright', ''),\n"
            "      StringStruct('OriginalFilename', 'QiGor_Wallpaper_Manager.exe'),\n"
            "      StringStruct('ProductName', 'QiGor Wallpaper Manager'),\n"
            "      StringStruct('ProductVersion', '0.7.0.0')])]),\n"
            "    VarFileInfo([VarStruct('Translation', [1033, 1200])])\n"
            "  ]\n"
            ")\n",
            encoding="utf-8")
        cmd += ["--version-file", str(ver_file)]

        cmd.append(str(ENTRY_PY))

        self._log("Command:", "info")
        self._log("  pyinstaller --onefile --windowed --collect-all tkinterdnd2 "
                  "--add-data app{sep}app --add-data assets{sep}assets {entry}".format(
                      sep=os.pathsep, entry=ENTRY_PY.name), "cmd")
        self._log("", "info")
        self._log("Running PyInstaller (30–90 seconds)...", "info")
        self._status("Building EXE… (please wait)")

        # ── Run ───────────────────────────────────────────────────────────────
        proc = subprocess.Popen(
            cmd, stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
            text=True, cwd=str(SCRIPT_DIR),
            creationflags=subprocess.CREATE_NO_WINDOW)

        line_count = 0
        for line in proc.stdout:
            line = line.rstrip()
            if not line:
                continue
            line_count += 1
            low = line.lower()
            if "error" in low:
                self._log_raw("  " + line, "error")
            elif "warning" in low:
                if line_count % 8 == 0:
                    self._log_raw("  … (warnings, normal)", "dim")
            elif any(k in line for k in ("Building", "Completed", "EXE")):
                self._log_raw("  " + line, "info")
            elif line_count % 15 == 0:
                short = line[:100] + ("…" if len(line) > 100 else "")
                self._log_raw("  " + short, "dim")
            self._status("Building… ({} lines)".format(line_count))

        proc.wait()

        if proc.returncode != 0:
            self._log("❌  PyInstaller failed (exit {})".format(
                proc.returncode), "error")
            return

        # ── Verify ────────────────────────────────────────────────────────────
        if not EXE_PATH.exists():
            # Try dist/ fallback
            dist_exe = DIST_DIR / EXE_NAME
            if dist_exe.exists():
                shutil.move(str(dist_exe), str(EXE_PATH))
            else:
                self._log("❌  EXE not found after build.", "error")
                return

        mb = EXE_PATH.stat().st_size / (1024 * 1024)
        self._log("✅  {} created!  ({:.1f} MB)".format(EXE_NAME, mb), "success")
        self._log("📁  {}".format(EXE_PATH), "path")

        # ── Clean build artifacts ──────────────────────────────────────────────
        for p in [BUILD_DIR, DIST_DIR, SPEC_FILE, ver_file,
                  SCRIPT_DIR / "qigor_wallpaper_manager.ico"]:
            pp = Path(p)
            if pp.exists():
                if pp.is_dir():
                    shutil.rmtree(pp, ignore_errors=True)
                else:
                    pp.unlink(missing_ok=True)

        elapsed = time.monotonic() - t0
        self._log("", "info")
        self._log("═" * 56, "header")
        self._log("  ✅  BUILD COMPLETE  —  {:.0f}s".format(elapsed), "success")
        self._log("  📦  {:.1f} MB  →  {}".format(mb, EXE_PATH), "success")
        self._log("═" * 56, "header")
        self._log("", "info")
        self._log("Next step: click 🐙 Upload Release to publish to GitHub.", "info")
        self._status("Build complete!  {:.1f} MB".format(mb))

    # ── GitHub release upload ─────────────────────────────────────────────────

    def _start_github(self):
        token = self._token_var.get().strip()
        if not token:
            messagebox.showerror("No Token",
                "Enter your GitHub Personal Access Token.\n\n"
                "Create one at: github.com/settings/tokens\n"
                "Required scope: repo")
            return
        if not EXE_PATH.exists():
            messagebox.showerror("No EXE",
                "EXE not found:\n{}\n\nBuild it first.".format(EXE_PATH))
            return
        self.cfg.set("github_token", token)
        self._thread(self._do_github)

    def _do_github(self):
        self._section("UPLOAD TO GITHUB RELEASE")
        token = self._token_var.get().strip()

        def gh_log(msg, tag="info"):
            self.root.after(0, lambda m=msg, t=tag: self._log(m, t))

        up = GitHubUploader(token, GITHUB_USER, GITHUB_REPO, gh_log)

        self._log("Target: github.com/{}/{}".format(GITHUB_USER, GITHUB_REPO), "info")
        self._log("Asset:  {}".format(EXE_NAME), "info")
        self._log("", "info")

        if not up.ensure_repo():
            return

        release_id, upload_url = up.get_or_create_release()
        if not release_id:
            return

        self._status("Uploading {}…".format(EXE_NAME))
        up.delete_asset(release_id, EXE_NAME)

        if up.upload_asset(upload_url, EXE_PATH, EXE_NAME):
            self._log("", "info")
            self._log("═" * 56, "header")
            self._log("  ✅  UPLOAD COMPLETE", "success")
            dl_url = ("https://github.com/{}/{}/releases/latest/"
                      "download/{}".format(GITHUB_USER, GITHUB_REPO, EXE_NAME))
            self._log("  🔗  {}".format(dl_url), "success")
            self._log("═" * 56, "header")
            self._status("Uploaded!")
        else:
            self._log("❌  Upload failed — check token has 'repo' scope.", "error")

    # ── Git source sync ───────────────────────────────────────────────────────

    def _git(self, *args):
        cmd = ["git"] + list(args)
        self._log("  $ {}".format(" ".join(cmd)), "dim")
        try:
            proc = subprocess.Popen(
                cmd, cwd=str(SCRIPT_DIR),
                stdout=subprocess.PIPE, stderr=subprocess.STDOUT,
                text=True,
                creationflags=subprocess.CREATE_NO_WINDOW)
            for line in proc.stdout:
                line = line.rstrip()
                if line:
                    self.root.after(0,
                        lambda l=line: self._log("    {}".format(l), "dim"))
            proc.wait()
            return proc.returncode
        except FileNotFoundError:
            self._log("git not found — install Git for Windows.", "error")
            return -1

    def _git_out(self, *args):
        try:
            r = subprocess.run(
                ["git"] + list(args), cwd=str(SCRIPT_DIR),
                capture_output=True, text=True,
                creationflags=subprocess.CREATE_NO_WINDOW)
            return r.stdout.strip(), r.returncode
        except FileNotFoundError:
            return "", -1

    def _git_setup(self):  self._thread(self._do_git_setup)
    def _git_commit(self): self._thread(self._do_git_commit)
    def _git_push(self):   self._thread(self._do_git_push)
    def _git_status(self): self._thread(self._do_git_status)

    def _do_git_setup(self):
        self._section("GIT SETUP")
        token = self._token_var.get().strip()

        # Create GitHub repo via API
        if token:
            def gh_log(msg, tag="info"):
                self.root.after(0, lambda m=msg, t=tag: self._log(m, t))
            up = GitHubUploader(token, GITHUB_USER, GITHUB_REPO, gh_log)
            up.ensure_repo()
        else:
            self._log("⚠   No token — skipping remote repo creation.", "warning")

        git_dir = SCRIPT_DIR / ".git"
        if git_dir.exists():
            self._log("Git repo already exists.", "warning")
            self._log("Use '2 – Commit' to stage and commit changes.", "info")
            return

        # Create .gitignore
        gi = SCRIPT_DIR / ".gitignore"
        if not gi.exists():
            gi.write_text(
                "# Build artifacts\n"
                "build/\ndist/\n*.spec\n\n"
                "# Generated EXE\n"
                "*.exe\n\n"
                "# Python cache\n"
                "*.pyc\n__pycache__/\n\n"
                "# Config (contains GitHub token)\n"
                "_slideshow_debug.txt\n"
                "_wallpaper_slideshow.py\n"
                "_wallpaper_remind.py\n"
                "_lockscreen_helper.py\n",
                encoding="utf-8")
            self._log("Created .gitignore", "info")

        self._git("init")
        self._git("add", "-A")
        rc = self._git("commit", "-m",
                       "Initial commit — QiGor Wallpaper Manager v0.7")
        if rc != 0:
            self._log("Commit failed — set git identity:", "error")
            self._log("  git config --global user.name 'Your Name'", "warning")
            self._log("  git config --global user.email 'you@example.com'", "warning")
            return

        repo_url = "https://github.com/{}/{}".format(GITHUB_USER, GITHUB_REPO)
        self._git("remote", "add", "origin", repo_url)
        self._log("", "info")
        self._log("✅  Setup complete!", "success")
        self._log("Click '3 – Push' to publish to GitHub.", "info")

    def _do_git_commit(self):
        self._section("GIT COMMIT")
        out, _ = self._git_out("status", "--short")
        if not out:
            self._log("Nothing changed — working tree is clean.", "warning")
            return
        self._log("Changes:\n{}".format(out), "info")
        self._git("add", "-A")
        stamp = datetime.now().strftime("%Y-%m-%d %H:%M")
        rc = self._git("commit", "-m", "Update {}".format(stamp))
        if rc == 0:
            self._log("✅  Committed. Click '3 – Push' to publish.", "success")
        else:
            self._log("Commit failed.", "error")

    def _do_git_push(self):
        self._section("GIT PUSH")
        self._log("Pushing to github.com/{}/{}...".format(
            GITHUB_USER, GITHUB_REPO), "info")
        rc = self._git("push", "-u", "origin", "main")
        if rc == 0:
            self._log("✅  Push complete!", "success")
            self._log("  https://github.com/{}/{}".format(
                GITHUB_USER, GITHUB_REPO), "success")
        else:
            self._log("Push failed — see output above.", "error")
            self._log("Common causes:", "warning")
            self._log("  • Repo doesn't exist yet — run '1 – Setup' first", "warning")
            self._log("  • Token doesn't have repo push access", "warning")
            self._log("  • Branch name: try 'master' if 'main' fails", "warning")

    def _do_git_status(self):
        self._section("GIT STATUS")
        out, _ = self._git_out("remote", "-v")
        self._log("Remote:  {}".format(out or "none"), "info")
        out, _ = self._git_out("log", "--oneline", "-5")
        self._log("Last 5 commits:\n{}".format(out or "  (none)"), "info")
        out, _ = self._git_out("status", "--short")
        if out:
            self._log("Uncommitted changes:\n{}".format(out), "warning")
        else:
            self._log("Working tree is clean.", "success")

    # ── Clean ─────────────────────────────────────────────────────────────────

    def _clean(self):
        removed = []
        for p in [BUILD_DIR, DIST_DIR, SPEC_FILE]:
            pp = Path(p)
            if pp.exists():
                if pp.is_dir():
                    shutil.rmtree(pp, ignore_errors=True)
                else:
                    pp.unlink()
                removed.append(pp.name)
        if removed:
            self._log("🧹  Removed: {}".format(", ".join(removed)), "info")
        else:
            self._log("Nothing to clean.", "info")

    # ── Close ─────────────────────────────────────────────────────────────────

    def _on_close(self):
        if self._busy:
            if not messagebox.askokcancel("Busy", "Operation running. Exit anyway?"):
                return
        self.cfg.set("window_geometry", self.root.geometry())
        self.cfg.set("github_token", self._token_var.get().strip())
        self.root.destroy()


