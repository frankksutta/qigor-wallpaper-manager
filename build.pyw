                            relief=tk.FLAT, cursor="hand2", command=cmd)
            btn.pack(side=tk.LEFT, fill=tk.X, expand=True, padx=2)
            Tooltip(btn, b["tip"])
            self._btns[key] = btn

        # ── Git source sync ───────────────────────────────────────────────────
        gitsf = tk.LabelFrame(content,
            text="  Source → GitHub  ({}/{})  ".format(GITHUB_USER, GITHUB_REPO))
